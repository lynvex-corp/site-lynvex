# Resend — envio de e-mail do formulário de contato
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=

# Upstash Redis — rate limiting distribuído (necessário para Vercel multi-instância)
# Crie um banco em: https://console.upstash.com → Redis → Create Database
# Copie "REST URL" e "REST Token" da aba "REST API"
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=